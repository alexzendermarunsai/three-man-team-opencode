{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "architect",
  "instructions": [
    "handoff/SESSION-CHECKPOINT.md"
  ],
  "skills": {
    "paths": [".opencode/skills"]
  },
  "agent": {
    "architect": {
      "mode": "primary"
    },
    "builder": {
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-6"
    },
    "reviewer": {
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-6"
    }
  }
}