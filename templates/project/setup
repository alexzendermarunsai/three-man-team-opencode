#!/bin/bash
# Three Man Team setup script — opencode edition

REPO_DIR="$(cd "$(dirname "$0")/../.." && pwd)"
TEMPLATE_GLOBAL="$REPO_DIR/templates/global"
TEMPLATE_PROJECT="$REPO_DIR/templates/project"

echo ""
echo "========================================="
echo "  Three Man Team — opencode"
echo "========================================="
echo ""

MODE="${1:-}"

if [ -z "$MODE" ]; then
  # Auto-detect: if repo is under ~/.config/opencode, default to global
  if [[ "$REPO_DIR" == "$HOME/.config/opencode"* ]]; then
    MODE="global"
  else
    MODE="project"
  fi
fi

if [ "$MODE" = "global" ]; then
  echo "Global install — agents and skills available in ALL opencode projects."
  echo ""

  GLOBAL_DIR="$HOME/.config/opencode"

  # Step 1 — Copy agents and skills into global opencode config
  echo "-----------------------------------------"
  echo "  Step 1 — Install global agents & skills"
  echo "-----------------------------------------"
  echo ""

  mkdir -p "$GLOBAL_DIR/agents" "$GLOBAL_DIR/skills/token-optimization"

  cp "$TEMPLATE_GLOBAL/agents/architect.md" "$GLOBAL_DIR/agents/architect.md"
  cp "$TEMPLATE_GLOBAL/agents/builder.md" "$GLOBAL_DIR/agents/builder.md"
  cp "$TEMPLATE_GLOBAL/agents/reviewer.md" "$GLOBAL_DIR/agents/reviewer.md"
  cp "$TEMPLATE_GLOBAL/skills/token-optimization/SKILL.md" "$GLOBAL_DIR/skills/token-optimization/SKILL.md"

  # Step 2 — Merge global opencode.json
  echo "-----------------------------------------"
  echo "  Step 2 — Merge global opencode.json"
  echo "-----------------------------------------"
  echo ""

  GLOBAL_CONFIG="$GLOBAL_DIR/opencode.json"
  if [ -f "$GLOBAL_CONFIG" ]; then
    echo "  You already have a global opencode.json at:"
    echo "    $GLOBAL_CONFIG"
    echo ""
    echo "  Three Man Team needs to add agent definitions and skill paths."
    echo "  Merge these keys into your existing config:"
    echo ""
    echo "  \"skills\": { \"paths\": [\".opencode/skills\"] },"
    echo "  \"agent\": {"
    echo "    \"architect\": { \"mode\": \"primary\" },"
    echo "    \"builder\": { \"mode\": \"subagent\", \"model\": \"anthropic/claude-sonnet-4-6\" },"
    echo "    \"reviewer\": { \"mode\": \"subagent\", \"model\": \"anthropic/claude-sonnet-4-6\" }"
    echo "  }"
    echo ""
    echo "  IMPORTANT: Do NOT add default_agent or instructions at the global level."
    echo "  Those are project-specific and belong in each project's opencode.json."
    echo ""
    echo "  See the template at: $TEMPLATE_GLOBAL/opencode.json"
  else
    cp "$TEMPLATE_GLOBAL/opencode.json" "$GLOBAL_CONFIG"
    echo "  Created $GLOBAL_CONFIG with agent definitions and skill paths."
    echo ""
    echo "  This config does NOT set default_agent or instructions — those are"
    echo "  project-specific and go in each project's opencode.json."
  fi

  # Step 3 — Instructions for each project
  echo ""
  echo "-----------------------------------------"
  echo "  Step 3 — Set up each project"
  echo "-----------------------------------------"
  echo ""
  echo "  For each project you want to use Three Man Team on:"
  echo ""
  echo "  cp -r $TEMPLATE_PROJECT/. /path/to/your/project/"
  echo "  cd /path/to/your/project"
  echo "  opencode"
  echo ""
  echo "  Switch to the architect agent (press Tab) and say: Read new-setup.md."
  echo ""

elif [ "$MODE" = "project" ]; then
  # Auto-detect project root
  PARENT_DIR="$(cd "$REPO_DIR/../.." && pwd)"
  if [ "$PARENT_DIR" != "$HOME" ]; then
    PROJECT_ROOT="$PARENT_DIR"
  else
    PROJECT_ROOT=""
  fi

  if [ -n "$PROJECT_ROOT" ]; then
    echo "Per-project install — detected project root: $PROJECT_ROOT"
  else
    echo "Per-project install — specify your project path below."
  fi
  echo ""

  # Step 1 — Copy project template files + global agents/skills into project
  echo "-----------------------------------------"
  echo "  Step 1 — Copy template files into your project"
  echo "-----------------------------------------"
  echo ""

  DEST="${PROJECT_ROOT:-/path/to/your/project}"

  echo "  Run these commands:"
  echo ""
  echo "  # Project state files (handoff, config, version, setup)"
  echo "  cp -r $TEMPLATE_PROJECT/. $DEST/"
  echo ""
  echo "  # Agent definitions (into project's .opencode/)"
  echo "  mkdir -p $DEST/.opencode/agents $DEST/.opencode/skills/token-optimization"
  echo "  cp $TEMPLATE_GLOBAL/agents/architect.md $DEST/.opencode/agents/"
  echo "  cp $TEMPLATE_GLOBAL/agents/builder.md $DEST/.opencode/agents/"
  echo "  cp $TEMPLATE_GLOBAL/agents/reviewer.md $DEST/.opencode/agents/"
  echo "  cp $TEMPLATE_GLOBAL/skills/token-optimization/SKILL.md $DEST/.opencode/skills/token-optimization/"
  echo ""

  if [ -n "$PROJECT_ROOT" ]; then
    echo "  Or run it now:"
    echo ""
    echo "  cp -r $TEMPLATE_PROJECT/. $PROJECT_ROOT/"
    echo "  mkdir -p $PROJECT_ROOT/.opencode/agents $PROJECT_ROOT/.opencode/skills/token-optimization"
    echo "  cp $TEMPLATE_GLOBAL/agents/architect.md $PROJECT_ROOT/.opencode/agents/"
    echo "  cp $TEMPLATE_GLOBAL/agents/builder.md $PROJECT_ROOT/.opencode/agents/"
    echo "  cp $TEMPLATE_GLOBAL/agents/reviewer.md $PROJECT_ROOT/.opencode/agents/"
    echo "  cp $TEMPLATE_GLOBAL/skills/token-optimization/SKILL.md $PROJECT_ROOT/.opencode/skills/token-optimization/"
  fi

  echo ""
  echo "-----------------------------------------"
  echo "  Step 2 — Start your first session"
  echo "-----------------------------------------"
  echo ""
  echo "  1. cd $DEST"
  echo "  2. Run opencode"
  echo "  3. Switch to the architect agent (press Tab)"
  echo "  4. Say: Read new-setup.md."
  echo ""
  echo "  Architect will introduce the team, set up your project context, and give you"
  echo "  the prompt to use every session going forward."
  echo ""

else
  echo "Usage: ./setup [project|global]"
  echo ""
  echo "  project  — Copy everything into a single project (default if not in ~/.config/)"
  echo "  global   — Install agents & skills into ~/.config/opencode/ (default if in ~/.config/)"
  echo ""
  exit 1
fi