# OS
.DS_Store

# opencode local dev config — not for users
.opencode/

# Override — template .opencode/ must ship with installs
!templates/project-folder/.opencode/
!templates/project-folder/.opencode/**
!templates/generic/.opencode/
!templates/generic/.opencode/**

# Internal docs — not for public commit
three-man-team-build-brief.md
INTERNAL-BRIEF.md

# Override global gitignore — docs/ is intentionally tracked (GitHub Pages)
!docs

# Override global *.json ignore — releases/ must be tracked
!releases/
!releases/*.json